{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "framework": "nextjs",
  "functions": {
    "src/app/api/documents/[id]/extract/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/zeron/sync/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/sheets/sync/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/sheets/sync",
      "schedule": "0 */2 * * *"
    }
  ]
}
