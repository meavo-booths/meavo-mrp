# Meavo MRP — environment variables
# Copy this file to .env.local for local development.
# In production, set the same variables in Vercel → Settings → Environment Variables.
# NEVER commit .env.local or any file containing real values.

# --- Public app URL (used in OAuth redirects, emails, etc.) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (https://supabase.com/dashboard/project/_/settings/api) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Postgres (https://supabase.com/dashboard/project/_/settings/database) ---
#
# In Supabase → Connect → copy the URI and replace [YOUR-PASSWORD].
# If your password has special characters (@ # : / etc.), URL-encode them
# (Supabase dashboard often does this when you copy).
#
# DATABASE_URL — Transaction pooler (port 6543) for the app / Vercel:
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# DIRECT_DATABASE_URL — for `pnpm db:push` (use Session pooler — works on IPv4-only networks):
# Supabase → Connect → Session pooler → URI → port 5432, user postgres.YOUR-PROJECT-REF
DIRECT_DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Direct db.*.supabase.co:5432 can fail with ENOTFOUND on some networks (IPv6-only DNS).
# DIRECT_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# --- Storage bucket names (must match buckets created in Supabase Storage) ---
SUPABASE_BUCKET_ORIGINALS=originals
SUPABASE_BUCKET_THUMBNAILS=thumbnails

# --- Google Gemini API (https://aistudio.google.com/) ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
# Set to 0 to disable thinking for predictable latency on document extraction.
GEMINI_THINKING_BUDGET=0

# --- Zeron sync adapter selection ---
# One of: "stub" | "export" | "api" | "agent"
# - "stub":   no-op, logs only (default during early build)
# - "export": generates XLSX/XML for manual import into Zeron (Plan B)
# - "api":    posts to Zeron's API (Plan A; requires ZERON_* below)
# - "agent":  posts to a desktop helper (Plan C)
ZERON_ADAPTER=stub
# Zeron API config (only required when ZERON_ADAPTER=api)
ZERON_API_BASE_URL=
ZERON_API_KEY=
# Zeron export config (only required when ZERON_ADAPTER=export)
ZERON_EXPORT_EMAIL=

# --- Default locale ---
NEXT_PUBLIC_DEFAULT_LOCALE=bg

# --- Legacy OCR invoice scanner (archived; default off) ---
ENABLE_INVOICE_SCANNER=false
NEXT_PUBLIC_ENABLE_INVOICE_SCANNER=false

