# Meavo MRP — environment variables
# Copy this file to .env.local for local development.
# In production, set the same variables in Vercel → Settings → Environment Variables.
# NEVER commit .env.local or any file containing real values.

# --- Public app URL (used in OAuth redirects, emails, etc.) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Shared MEAVO Neon Postgres (same DATABASE_URL as meavo-gateway) ---
# Vercel → meavo-gateway → Settings → Environment Variables → DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST-pooler.neon.tech/neondb?sslmode=require

# --- NextAuth (Google SSO via gateway User + ToolCardAccess) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Tool card that grants access to this app (seeded in meavo-gateway)
MRP_TOOL_CARD_ID=seed-mrp-tool
GATEWAY_URL=https://meavo.app

# --- Vercel Blob (original document files) ---
# Vercel → meavo-mrp → Storage → Blob → BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=

# --- Google Gemini API (https://aistudio.google.com/) ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
# Set to 0 to disable thinking for predictable latency on document extraction.
GEMINI_THINKING_BUDGET=0

# --- Zeron sync adapter selection ---
# One of: "stub" | "export" | "api" | "agent"
# - "stub":   no-op, logs only (default during early build)
# - "export": generates XLSX/XML for manual import into Zeron (Plan B)
# - "api":    posts to Zeron's API (Plan A; requires ZERON_* below)
# - "agent":  posts to a desktop helper (Plan C)
ZERON_ADAPTER=stub
# Zeron API config (only required when ZERON_ADAPTER=api)
ZERON_API_BASE_URL=
ZERON_API_KEY=
# Zeron export config (only required when ZERON_ADAPTER=export)
ZERON_EXPORT_EMAIL=

# Zeron inbound webhook (Zeron POSTs to /api/zeron/inbound)
# Provide at least one auth method to Zeron. Token is preferred.
ZERON_WEBHOOK_TOKEN=
# ZERON_WEBHOOK_USER=meavo-mrp
# ZERON_WEBHOOK_PASSWORD=

# --- Default locale ---
NEXT_PUBLIC_DEFAULT_LOCALE=bg

# --- Legacy OCR invoice scanner (archived; default off) ---
ENABLE_INVOICE_SCANNER=false
NEXT_PUBLIC_ENABLE_INVOICE_SCANNER=false

# --- Master data Google Sheet (Materials / ElementBOM CSV source) ---
# GOOGLE_MASTER_DATA_SHEET_ID=1YGDc0uuDF9DhSOV19JYceXqPmIL8tFfCmMNwlV0JwGQ
# GOOGLE_MASTER_DATA_BOM_GID=51553840

# --- Google Sheets production sync ---
# GOOGLE_SHEETS_MASTER_ID=1aly6kRe_01ZDH_MnzaTtH6uVrqdsUX_p8AUAvt8EdO4
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
CRON_SECRET=generate-a-random-string

# Shared bearer secret for RP app → POST /api/stock/rp-deduct
# Must match RP_MRP_DEDUCT_SECRET in meavo-rp
# RP_MRP_DEDUCT_SECRET=
